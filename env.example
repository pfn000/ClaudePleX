"""
utils/plex_validator.py
╰──➤ PleX syntax validator — enforces NCOM Systems canonical rules
"""

import re
from enum import Enum


class FileType(Enum):
    PLX        = "plx"
    PLXCODE    = "plxcode"
    ATTRIBUTES = "attributes"
    MF         = "mf"
    BUN        = "bun"
    NUDE       = "nude"


# Commands that require autocorrection
AUTOCORRECT_MAP = {
    r"\bHail~!!":    "Hail |",
    r"\bBuild~!!":   "Build |",
    r"\bShow~!!":    "Show |",
    r"\bSend~!!":    "Send |",
    r"\bBundle~!!":  "Bundle |",
    r"\bLink~!!":    "|~|",
    r"\|__>":        "╰──➤",
}

# Valid canonical commands (never-autocorrected or already canonical)
VALID_COMMANDS = {
    "Hail |", "Build |", "Show |", "Send |", "Bundle |",
    "Call~!!", "Check~!!", "Sign~!!", "Argu~!!", "Math~!!",
    "Logic~!!", "Store~!!", "Sniff~!!", "Pulse~!!",
    "Script~!!", "Mark~!!", "Panel~!!", "UI~!!", "TAG~!!",
    "|~|", "|~|~!!", "|!!|",
}

# Lone flow operator — illegal
BARE_FLOW_PATTERN = re.compile(r"^[╰\s]*──➤\s*$", re.MULTILINE)

# Comment pattern
COMMENT_PATTERN = re.compile(r"^/!!")


class PlexValidator:
    """Validate PleX code and return structured diagnostics."""

    def validate(self, code: str) -> dict:
        errors        = []
        warnings      = []
        autocorrects  = []

        lines  = code.split("\n")
        output_lines = []

        for i, line in enumerate(lines, start=1):
            original = line
            stripped = line.strip()

            # Skip comments and empty lines
            if not stripped or COMMENT_PATTERN.match(stripped):
                output_lines.append(line)
                continue

            # Apply autocorrections
            corrected = line
            for pattern, replacement in AUTOCORRECT_MAP.items():
                new = re.sub(pattern, replacement, corrected)
                if new != corrected:
                    autocorrects.append(
                        f"Line {i}: `{corrected.strip()}` → `{new.strip()}`"
                    )
                    corrected = new

            output_lines.append(corrected)

            # Check for bare ╰──➤ (never allowed alone)
            if re.match(r"^\s*╰──➤\s*$", corrected):
                errors.append(f"Line {i}: Bare `╰──➤` — must be nested under a command")

            # Warn on Pulse~!! if it looks malformed
            if "Pulse~!!" in corrected:
                if "n~" not in corrected and "|~|" not in corrected:
                    warnings.append(
                        f"Line {i}: `Pulse~!!` without `n~` or `|~|` — verify bare-metal target"
                    )

            # Warn on @references without .attributes hail
            if re.search(r"@\w+", corrected) and i == 1 and "Hail" not in corrected:
                warnings.append(
                    f"Line {i}: Using `@reference` — consider starting with `Hail | @attributes`"
                )

        # Check for Sign~!! at end
        non_empty = [l.strip() for l in output_lines if l.strip() and not l.strip().startswith("/!!")]
        if non_empty and non_empty[-1] != "Sign~!!":
            warnings.append("File does not end with `Sign~!!` — state may be unlocked")

        return {
            "valid":        len(errors) == 0,
            "errors":       errors,
            "warnings":     warnings,
            "autocorrects": autocorrects,
            "corrected":    "\n".join(output_lines),
        }
